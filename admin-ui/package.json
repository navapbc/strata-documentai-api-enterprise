{
  "name": "docai-admin-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "esbuild js/main.js --bundle --outfile=dist/bundle.js --sourcemap --watch --serve=3000 --servedir=. --loader:.html=text",
    "build": "esbuild js/main.js --bundle --outfile=dist/bundle.js --minify --loader:.html=text",
    "lint": "eslint js/",
    "format": "prettier --write js/ styles/",
    "format:check": "prettier --check js/ styles/",
    "preview": "python3 -m http.server 3000"
  },
  "devDependencies": {
    "esbuild": "^0.21.0",
    "eslint": "^10.4.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
