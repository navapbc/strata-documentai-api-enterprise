{
  "name": "docai-admin-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "esbuild src/main.js --bundle --outfile=dist/bundle.js --sourcemap --watch --serve=3000 --servedir=. --loader:.html=text",
    "build": "esbuild src/main.js --bundle --outfile=dist/bundle.js --minify --loader:.html=text",
    "lint": "eslint src/ tests/ e2e/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write src/ styles/ tests/ e2e/",
    "format:check": "prettier --check src/ styles/ tests/ e2e/",
    "preview": "python3 -m http.server 3000"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
