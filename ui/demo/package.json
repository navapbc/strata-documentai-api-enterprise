{
  "name": "docai-demo-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "esbuild src/main.js styles/style.css --bundle --outdir=dist --outbase=. --sourcemap --watch --serve=3001 --servedir=. --loader:.html=text",
    "build": "esbuild src/main.js styles/style.css --bundle --outdir=dist --outbase=. --minify --loader:.html=text",
    "lint": "eslint src/ tests/",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write src/ styles/ tests/",
    "format:check": "prettier --check src/ styles/ tests/"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
